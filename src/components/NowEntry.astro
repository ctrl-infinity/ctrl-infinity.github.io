---
export interface Props {
  title: string;
  description: string;
  tags: string[];
  startDate?: string;
  link?: string;
}

const { title, description, tags, startDate, link } = Astro.props;
---

<div class="flex flex-col gap-2 py-6" data-reveal>
  <div class="flex items-baseline justify-between gap-4">
    <h3 class="text-lg font-medium text-foreground">
      {
        link ? (
          <a
            href={link}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-accent transition-colors duration-300"
          >
            {title} ↗
          </a>
        ) : (
          title
        )
      }
    </h3>
    {
      startDate && (
        <span class="text-xs font-mono text-gray-400 shrink-0">{startDate}</span>
      )
    }
  </div>

  <p class="text-gray-600 leading-relaxed max-w-[60ch]">
    {description}
  </p>

  <div class="flex flex-wrap gap-2 mt-1">
    {
      tags.map((tag) => (
        <span class="px-2 py-0.5 bg-black/5 text-xs text-foreground/70 font-mono">
          {tag}
        </span>
      ))
    }
  </div>
</div>

<script>
  import { setupReveal } from '../scripts/reveal';
  setupReveal();
</script>
